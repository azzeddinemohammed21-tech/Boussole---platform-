<!DOCTYPE html>
<html>
<head>
    <title>حاسبة مؤشر بوصلة+ للكفاءة (BCI)</title>
    <style>
        body { font-family: Arial; max-width: 600px; margin: auto; padding: 20px; direction: rtl; }
        .dimension { margin: 10px 0; }
        input[type="range"] { width: 80%; }
        .result { background: #f0f0f0; padding: 15px; border-radius: 8px; margin-top: 20px; }
    </style>
</head>
<body>
    <h1>🧭 مؤشر بوصلة+ للكفاءة (BCI)</h1>
    <form id="bci-form">
        {% for dim, weight in dimensions.items() %}
        <div class="dimension">
            <label>{{ dim }} (الوزن: {{ weight }}%):</label>
            <input type="range" name="{{ dim }}" min="0" max="10" step="0.5" value="5" oninput="this.nextElementSibling.value=this.value">
            <span>5</span>
        </div>
        {% endfor %}
        <button type="submit">احسب مؤشري</button>
    </form>
    <div id="result" class="result"></div>

    <script>
        document.getElementById('bci-form').onsubmit = async (e) => {
            e.preventDefault();
            const form = e.target;
            const data = new FormData(form);
            const response = await fetch('/calculate', { method: 'POST', body: data });
            const result = await response.json();
            document.getElementById('result').innerHTML = `
                <h2>نتيجة مؤشر BCI: ${result.bci} من 100</h2>
                <p><strong>مستوى الكفاءة:</strong> ${result.level}</p>
                <h3>تفاصيل الأبعاد:</h3>
                <ul>${Object.entries(result.dimensions).map(([k,v]) => `<li>${k}: ${v}/10</li>`).join('')}</ul>
            `;
        };
    </script>
</body>
</html>
